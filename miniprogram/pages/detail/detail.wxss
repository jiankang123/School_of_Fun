/* pages/detail/detail.wxss */

page { background: #F5F5F7; }

.container {
  padding: 32rpx 32rpx 60rpx;
  min-height: 100vh;
}

/* 问题卡片 */
.q-card {
  background: linear-gradient(135deg, #FF6B35 0%, #FF4500 100%);
  border-radius: 40rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 16rpx 48rpx rgba(255,107,53,0.28);
}
.q-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}
.q-num {
  background: rgba(255,255,255,0.25);
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  padding: 6rpx 20rpx;
  border-radius: 40rpx;
}
.q-cat {
  background: rgba(255,255,255,0.2);
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  padding: 6rpx 20rpx;
  border-radius: 40rpx;
}
.q-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.6;
}

/* 答案卡片 */
.answer-card {
  background: #fff;
  border-radius: 36rpx;
  padding: 36rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
  margin-bottom: 24rpx;
}
.answer-label {
  font-size: 24rpx;
  font-weight: 700;
  color: #FF6B35;
  letter-spacing: 2rpx;
  margin-bottom: 28rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #F0F0F0;
}
.answer-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
  white-space: pre-wrap;
  margin-bottom: 8rpx;
}

/* 步骤 */
.steps { margin-top: 8rpx; }
.step-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 20rpx;
}
.step-dot {
  flex-shrink: 0;
  width: 44rpx; height: 44rpx;
  background: #FF6B35;
  color: #fff;
  border-radius: 50%;
  font-size: 24rpx;
  font-weight: 700;
  text-align: center;
  line-height: 44rpx;
  margin-top: 4rpx;
}
.step-text {
  flex: 1;
  font-size: 28rpx;
  color: #555;
  line-height: 1.7;
}

/* 上下翻按钮 */
.nav-btns {
  display: flex;
  gap: 20rpx;
}
.nav-btn {
  flex: 1;
  padding: 28rpx;
  background: #fff;
  border-radius: 28rpx;
  border: 3rpx solid #F0F0F0;
  font-size: 28rpx;
  color: #555;
  text-align: center;
}
.nav-btn.disabled {
  opacity: 0.3;
  pointer-events: none;
}
