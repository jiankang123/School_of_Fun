/* pages/stage/stage.wxss */
.page { background: #FFF9F0; min-height: 100vh; }

.stage-hd { padding: 0 40rpx 48rpx; position: relative; overflow: hidden; }
.stage-hd::before {
  content: '';
  position: absolute;
  width: 560rpx; height: 560rpx;
  border-radius: 50%;
  background: rgba(255,255,255,.07);
  bottom: -240rpx; right: -120rpx;
}
.sb { height: 16rpx; }
.nav { display: flex; align-items: center; justify-content: space-between; margin-bottom: 32rpx; }
.nav-back { width: 72rpx; height: 72rpx; border-radius: 50%; background: rgba(255,255,255,.25); display: flex; align-items: center; justify-content: center; font-size: 44rpx; color: #fff; }
.nav-title { font-size: 36rpx; font-weight: 800; color: #fff; }
.nav-ph { width: 72rpx; }
.stage-hero { text-align: center; }
.stage-big { font-size: 128rpx; display: block; margin-bottom: 8rpx; animation: float 3s ease-in-out infinite; }
.stage-dc { font-size: 26rpx; color: rgba(255,255,255,.85); margin-bottom: 24rpx; }
.stage-pr { display: flex; align-items: center; gap: 20rpx; }
.stage-pr .pb { flex: 1; height: 16rpx; background: rgba(255,255,255,.25); }
.stage-pr .pf { background: rgba(255,255,255,.9); }
.stage-pl { font-size: 26rpx; color: rgba(255,255,255,.9); font-weight: 600; white-space: nowrap; }

.lv-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28rpx; padding: 40rpx 32rpx 48rpx; }
.lv-cell { display: flex; flex-direction: column; align-items: center; gap: 10rpx; }
.lv-btn {
  width: 144rpx; height: 144rpx; border-radius: 44rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 56rpx;
  box-shadow: 0 8rpx 28rpx rgba(0,0,0,.12);
  position: relative;
}
.lv-btn.locked { background: #E0E0E0 !important; box-shadow: none !important; opacity: .6; }
.lv-done-badge { position: absolute; top: -12rpx; right: -8rpx; font-size: 32rpx; color: #FFB300; }
.lv-name { font-size: 22rpx; color: #666; font-weight: 500; text-align: center; line-height: 1.3; max-width: 144rpx; }
.lv-stars { display: flex; gap: 4rpx; }
.lv-stars text { font-size: 22rpx; color: #ddd; }
.lv-stars text.lit { color: #FFB300; }

.safe { height: 40rpx; }
