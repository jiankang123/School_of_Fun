/* pages/reward/reward.wxss */
page { background: linear-gradient(160deg, #FFB300 0%, #FF6F00 100%); min-height: 100vh; }

.page {
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  min-height: 100vh; padding: 60rpx 48rpx;
}

.firework {
  font-size: 80rpx; margin-bottom: 16rpx;
  animation: bounce 0.6s ease infinite alternate;
}
@keyframes bounce {
  from { transform: translateY(0) rotate(-10deg); }
  to   { transform: translateY(-20rpx) rotate(10deg); }
}

.reward-card {
  background: #fff; border-radius: 48rpx;
  padding: 56rpx 40rpx; width: 100%;
  text-align: center; margin-bottom: 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.15);
}
.result-emoji { font-size: 100rpx; margin-bottom: 16rpx; }
.result-title { font-size: 48rpx; font-weight: 800; color: #2D2D2D; margin-bottom: 8rpx; }
.result-sub { font-size: 28rpx; color: #888; margin-bottom: 40rpx; }

.stars-row {
  display: flex; justify-content: center; gap: 20rpx;
  margin-bottom: 28rpx;
}
.star-wrap {
  font-size: 80rpx; color: #E0E0E0;
  transition: all 0.3s;
}
.star-wrap.lit {
  color: #FFB300;
  animation: star-pop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}
@keyframes star-pop {
  from { transform: scale(0); opacity: 0; }
  to   { transform: scale(1); opacity: 1; }
}

.earn-row { display: flex; justify-content: center; }
.earn-tag {
  background: #FFF8E1; color: #FF8F00;
  font-size: 28rpx; font-weight: 700;
  padding: 12rpx 32rpx; border-radius: 40rpx;
}

.action-btns {
  display: flex; gap: 20rpx; width: 100%; margin-bottom: 28rpx;
}
.half-btn { flex: 1; }

.back-link {
  font-size: 26rpx; color: rgba(255,255,255,0.8);
  text-decoration: underline;
  padding: 12rpx;
}
