/* pages/game/game.wxss */
page { background: #FFF9F0; }

/* ── 顶部进度栏 ── */
.game-hd {
  display: flex; align-items: center; gap: 20rpx;
  padding: 80rpx 24rpx 20rpx;
  background: #fff;
  border-bottom: 1rpx solid #F5F5F5;
}
.back-btn {
  width: 64rpx; height: 64rpx; border-radius: 50%;
  background: #F5F5F5;
  display: flex; align-items: center; justify-content: center;
  font-size: 44rpx; color: #555; flex-shrink: 0;
}
.hd-center { flex: 1; }
.hd-title { font-size: 28rpx; font-weight: 700; color: #2D2D2D; margin-bottom: 10rpx; }
.prog-bar { height: 12rpx; background: #F0F0F0; border-radius: 6rpx; overflow: hidden; }
.prog-fill { height: 100%; border-radius: 6rpx; transition: width 0.4s; }
.lives { font-size: 32rpx; flex-shrink: 0; letter-spacing: 4rpx; }

/* ── 游戏主体 ── */
.game-body { padding: 40rpx 32rpx; }

/* count 游戏 */
.q-label {
  text-align: center; font-size: 32rpx; font-weight: 700;
  color: #2D2D2D; margin-bottom: 40rpx;
}
.items-display {
  display: flex; flex-wrap: wrap;
  justify-content: center; gap: 16rpx;
  background: #fff; border-radius: 32rpx;
  padding: 32rpx; margin-bottom: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  min-height: 180rpx;
}
.item-dot {
  font-size: 64rpx; line-height: 1;
  transition: all 0.2s;
}
.item-dot:active { transform: scale(1.3); }
.item-dot.counted {
  opacity: 0.25;
  transform: scale(0.75);
}

.counted-display {
  text-align: center; margin-bottom: 32rpx;
}
.counted-label { font-size: 24rpx; color: #AAAAAA; margin-bottom: 4rpx; }
.counted-num { font-size: 80rpx; font-weight: 800; color: #FFB300; line-height: 1; }

/* 数字选项 */
.options-grid {
  display: grid; grid-template-columns: repeat(5, 1fr); gap: 16rpx;
}
.opt-btn {
  aspect-ratio: 1;
  background: #fff; border-radius: 24rpx;
  border: 4rpx solid #E8E8E8;
  font-size: 48rpx; font-weight: 700; color: #2D2D2D;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
  transition: all 0.15s;
}
.opt-btn:active { transform: scale(0.92); }
.opt-btn.correct {
  background: #66BB6A;
  border-color: #66BB6A;
  color: #fff;
}
.opt-btn.wrong {
  background: #EF5350;
  border-color: #EF5350;
  color: #fff;
}

/* ── match 游戏 ── */
.match-area {
  display: flex; align-items: center;
  gap: 0; position: relative;
  min-height: 500rpx;
}
.match-col {
  flex: 1; display: flex; flex-direction: column;
  gap: 20rpx; padding: 8rpx;
}
.line-canvas {
  width: 100rpx; height: 500rpx; flex-shrink: 0;
}
.match-item {
  background: #fff; border-radius: 20rpx;
  border: 4rpx solid #E8E8E8;
  padding: 20rpx 0; text-align: center;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
  transition: all 0.15s;
}
.match-item:active { transform: scale(0.95); }
.number-item { font-size: 48rpx; font-weight: 800; color: #2D2D2D; }
.dot-item { font-size: 24rpx; color: #555; line-height: 1.6; }
.match-item.selected { border-color: #FFB300; background: #FFF8E1; }
.match-item.matched {
  border-color: #66BB6A; background: #F1F8F1;
  opacity: 0.6;
}

/* ── 反馈 Toast ── */
.feedback-toast {
  position: fixed; bottom: 200rpx; left: 50%;
  transform: translateX(-50%);
  padding: 20rpx 40rpx; border-radius: 50rpx;
  font-size: 30rpx; font-weight: 700; color: #fff;
  z-index: 100;
  animation: toast-in 0.3s ease;
}
.feedback-toast.correct { background: #66BB6A; }
.feedback-toast.wrong { background: #EF5350; }
@keyframes toast-in {
  from { transform: translateX(-50%) translateY(20rpx); opacity: 0; }
  to   { transform: translateX(-50%) translateY(0); opacity: 1; }
}
